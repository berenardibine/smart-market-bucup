{
  "rewrites": [
    // OG preview (for bots only)
    {
      "source": "/api/og/p/:slug",
      "destination": "https://tsrnmrnfmvsivnvdkqrj.supabase.co/functions/v1/og-preview?slug=:slug"
    },
    {
      "source": "/api/og/c/:slug",
      "destination": "https://tsrnmrnfmvsivnvdkqrj.supabase.co/functions/v1/og-preview?category=:slug"
    },

    // REAL USER ROUTES (SPA)
    { "source": "/p/:slug", "destination": "/index.html" },
    { "source": "/p/(.*)", "destination": "/index.html" },

    { "source": "/products/:slug", "destination": "/index.html" },
    { "source": "/products/(.*)", "destination": "/index.html" },

    { "source": "/category/:slug", "destination": "/index.html" },
    { "source": "/shop/:id", "destination": "/index.html" },

    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
