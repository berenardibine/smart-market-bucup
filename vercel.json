    { "source": "/products/:name/by/:seller", "destination": "/index.html" },
    { "source": "/products/:name", "destination": "/index.html" },
    { "source": "/opportunities/:title/by/:poster", "destination": "/index.html" },
    { "source": "/opportunities/:title", "destination": "/index.html" },
    { "source": "/equipment/:name/by/:owner", "destination": "/index.html" },
