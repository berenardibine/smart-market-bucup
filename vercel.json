{
  "rewrites": [
    { "source": "/p/:slug", "destination": "https://tsrnmrnfmvsivnvdkqrj.supabase.co/functions/v1/og-preview?slug=:slug" },
    { "source": "/sitemap.xml", "destination": "https://tsrnmrnfmvsivnvdkqrj.supabase.co/functions/v1/generate-sitemap" },
    { "source": "/products/:name/by/:seller", "destination": "/index.html" },
    { "source": "/products/:name", "destination": "/index.html" },
    { "source": "/opportunities/:title/by/:poster", "destination": "/index.html" },
    { "source": "/opportunities/:title", "destination": "/index.html" },
    { "source": "/equipment/:name/by/:owner", "destination": "/index.html" },
    { "source": "/equipment/:name", "destination": "/index.html" },
    { "source": "/agriculture/:product/by/:farmer", "destination": "/index.html" },
    { "source": "/agriculture/:product", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/p/:slug",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.woff2",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }
      ]
    },
    {
      "source": "/(.*)\\.jpg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }
      ]
    },
    {
      "source": "/(.*)\\.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" },
        { "key": "Content-Type", "value": "application/xml" }
      ]
    }
  ]
}
